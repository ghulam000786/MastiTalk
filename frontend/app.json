{
  "expo": {
    "name": "mastitalk",
    "slug": "mastitalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "android": {
      "package": "com.ghulam000786.mastitalk",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "MastiTalk ko camera access chahiye video call ke liye",
          "microphonePermission": "MastiTalk ko mic access chahiye voice call ke liye",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "MastiTalk ko mic access chahiye voice message ke liye"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b9c2370c-8ba9-4624-919a-879be8b1987e"
      }
    },
    "owner": "ghulam000786"
  }
}
