{
  "expo": {
    "name": "mastitalk",
    "slug": "mastitalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "extra": {
      "eas": {
        "projectId": "14c30663-44cc-4515-9add-744c430a031a"
      }
    },
    "android": {
      "package": "com.rehan.mastitalk",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "MastiTalk ko camera access chahiye video call ke liye",
          "microphonePermission": "MastiTalk ko mic access chahiye voice call ke liye",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "MastiTalk ko mic access chahiye voice message ke liye"
        }
      ]
    ]
  }
}
